# Job-Queue App Configuration
# Number of concurrent workers (positive integer)
WORKER_COUNT=10

# Address of the Redis instance (e.g., redis:6379 or localhost:6379)
REDIS_ADDR=redis:6379

# PostgreSQL connection string (e.g., postgres://user:password@host:port/dbname?sslmode=disable)
DATABASE_URL=postgres://user:yoursupersecurepassword@postgres:5432/jobqueue?sslmode=disable

# PostgreSQL Database Configuration (used by postgres service in docker-compose)
POSTGRES_USER=user
POSTGRES_PASSWORD=yoursupersecurepassword
POSTGRES_DB=jobqueue

# Task time-to-live before being cleaned up from the store (e.g., 1h, 30m)
TASK_TTL=1h

# HTTP Server timeouts (e.g., 5s, 10s, 120s)
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=120s

# Grafana Configuration (used by grafana service in docker-compose)
GF_SECURITY_ADMIN_PASSWORD=yoursupersecurepassword

# Docker Image Configuration
DOCKER_USERNAME=yourusername